# LLM Configuration
ANTHROPIC_API_KEY=sk-ant-your-api-key-here

# Auth — set a password to protect the web UI (leave empty for no auth)
ADMIN_PASSWORD=your-password-here

# Database
DATABASE_URL=sqlite:///F:/novel-writer-agent/data/novels.db

# Paths
OUTPUT_DIR=F:/novel-writer-agent/output
DATA_DIR=F:/novel-writer-agent/data
LOG_DIR=F:/novel-writer-agent/logs

# Scheduling (Asia/Shanghai timezone)
NOVEL_MORNING_TIME=08:00
NOVEL_EVENING_TIME=20:00

# Budget
NOVEL_MONTHLY_BUDGET=25.00
